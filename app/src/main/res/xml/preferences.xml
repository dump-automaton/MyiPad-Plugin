<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <SwitchPreferenceCompat
        app:key="skip_hardware_certification"
        app:title="Skip hardware certification"
        app:defaultValue="true"/>

    <ListPreference
        app:key="pref_hardware_info"
        app:title="Select the hardware info profile"
        app:entries="@array/hardware_info_profile_names"
        app:entryValues="@array/hardware_info_profile_values"
        app:defaultValue="p350"/>

    <SwitchPreferenceCompat
        app:key="skip_elm"
        app:title="Skip elm activation"
        app:defaultValue="true"/>

    <SwitchPreferenceCompat
        app:key="disable_auto_update"
        app:title="Disable auto update"
        app:defaultValue="true"/>

    <SwitchPreferenceCompat
        app:key="block_root_access_requests"
        app:title="Block root access requests"
        app:defaultValue="true"/>

    <SwitchPreferenceCompat
        app:key="enable_apply_changes_instantly"
        app:title="Apply changes instantly"
        app:summary="Apply settings without restarting the device. If you encounter any exceptions, please consider disabling it."
        app:defaultValue="true"/>

    <Preference
        app:key="apply_changes"
        app:title="Apply changes"
        app:dependency="enable_apply_changes_instantly"/>

</PreferenceScreen>