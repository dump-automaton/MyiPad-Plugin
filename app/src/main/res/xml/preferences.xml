<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">

    <PreferenceCategory
        android:title="MyiPad Tweaks">
        <CheckBoxPreference
            android:key="disable_mdm"
            android:title="Disable MDM"
            android:defaultValue="true"/>
        <CheckBoxPreference
            android:key="disable_auto_update"
            android:title="Disable auto update"
            android:defaultValue="true"/>
        <CheckBoxPreference
            android:key="cancelable_dialog"
            android:title="Make all dialog cancelable"/>
        <Preference
            android:key="remove_fragment"
            android:title="Close"/>
    </PreferenceCategory>

    <PreferenceCategory
        android:title="Debug">
        <Preference
            android:key="dump_logcat"
            android:title="Dump logcat"/>
    </PreferenceCategory>

</PreferenceScreen>