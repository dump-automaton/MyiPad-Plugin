<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">

    <PreferenceCategory
        android:title="MyiPad Tweaks"/>

    <SwitchPreference
        android:key="skip_hardware_certification"
        android:title="Skip hardware certification"
        android:defaultValue="true"/>

    <SwitchPreference
        android:key="skip_elm"
        android:title="Skip elm activation"
        android:defaultValue="true"/>

    <SwitchPreference
        android:key="block_auto_update"
        android:title="Block auto update"
        android:defaultValue="true"/>

    <SwitchPreference
        android:key="block_screen_capture"
        android:title="Block screen capture"
        android:defaultValue="true"/>

</PreferenceScreen>